{
  "mcpServers": {
    "arifOS": {
      "command": "python",
      "args": ["stdio_server.py"],
      "cwd": "/root/arifOS",
      "env": {
        "ARIFOS_DEPLOYMENT": "local",
        "ARIFOS_MINIMAL_STDIO": "1"
      }
    },
    "meyhem": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://api.rhdxm.com/mcp/"],
      "description": "Meyhem — MCP server discovery (6,700+) + outcome-ranked web search. No API key."
    }
  }
}
