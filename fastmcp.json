{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.12",
    "dependencies": [
      "fastmcp>=3.2.0",
      "fastapi>=0.100.0",
      "uvicorn>=0.22.0",
      "pydantic>=2.0.0",
      "prefab-ui>=0.1.0",
      "python-dotenv>=1.0.0"
    ]
  },
  "deployment": {
    "transport": "http",
    "host": "0.0.0.0",
    "port": 8000,
    "log_level": "INFO",
    "env": {
      "ARIFOS_VERSION": "2026.4.13",
      "ARIFOS_DEPLOYMENT": "horizon",
      "ARIFOS_ENABLE_CORS": "true",
      "ARIFOS_RATE_LIMIT_ENABLED": "true",
      "ARIFOS_RATE_LIMIT_CAPACITY": "120",
      "ARIFOS_RATE_LIMIT_REFILL_PER_SEC": "2.0",
      "ARIFOS_HTTP_BODY_LIMIT_ENABLED": "true",
      "ARIFOS_HTTP_MAX_BODY_BYTES": "1048576"
    }
  },
  "name": "arifOS Sovereign Intelligence Kernel",
  "description": "Constitutional AI governance kernel — 13 Floors, Trinity Architecture (ΔΩΨ). Horizon gateway over the sovereign VPS execution plane.",
  "version": "2026.4.13",
  "website": "https://arifosmcp.arif-fazil.com",
  "documentation": "https://github.com/ariffazil/arifOS",
  "license": "AGPL-3.0-only",
  "tags": [
    "ai-governance",
    "constitutional-ai",
    "mcp-server",
    "trinity-architecture",
    "agi-asi-apex",
    "hallucination-prevention",
    "merkle-audit",
    "thermodynamic-governance"
  ]
}
