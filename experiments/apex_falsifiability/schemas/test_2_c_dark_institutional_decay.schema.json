{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arifos.local/schemas/apex_falsifiability/test_2_c_dark_institutional_decay.schema.json",
  "title": "APEX Test 2 - C_dark predicts institutional decay",
  "description": "JSONL row schema for testing whether dimensionless C_dark = A * (1 - P) * (1 - X) * Q separates historical collapse/scandal cases from stable peer controls.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_id",
    "sample_id",
    "organization",
    "case_label",
    "time_window",
    "source_corpus",
    "c_dark_scores",
    "ground_truth",
    "analysis"
  ],
  "properties": {
    "experiment_id": {
      "const": "test_2_c_dark_institutional_decay"
    },
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "organization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sector", "jurisdiction"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "sector": {"type": "string", "minLength": 1},
        "jurisdiction": {"type": "string", "minLength": 1},
        "peer_group_id": {"type": "string"}
      }
    },
    "case_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "label_blinded_for_scorer"],
      "properties": {
        "class": {"enum": ["collapse_case", "stable_control"]},
        "label_blinded_for_scorer": {"type": "boolean", "const": true},
        "case_notes": {"type": "string"}
      }
    },
    "time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date", "years_before_event"],
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"},
        "years_before_event": {"type": "number", "minimum": 0},
        "event_date": {"type": ["string", "null"], "format": "date"}
      }
    },
    "source_corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_count", "corpus_hash", "source_types"],
      "properties": {
        "document_count": {"type": "integer", "minimum": 1},
        "corpus_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
        "source_types": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["annual_report", "press_release", "speech", "regulatory_filing", "news_interview", "other"]}
        },
        "source_manifest_path": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "c_dark_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["a_capability_or_clarity", "p_stability", "x_ethics_alignment", "q_action_potential", "c_dark"],
      "properties": {
        "a_capability_or_clarity": {"type": "number", "minimum": 0, "maximum": 1},
        "p_stability": {"type": "number", "minimum": 0, "maximum": 1},
        "x_ethics_alignment": {"type": "number", "minimum": 0, "maximum": 1},
        "q_action_potential": {"type": "number", "minimum": 0, "maximum": 1},
        "c_dark": {"type": "number", "minimum": 0, "maximum": 1},
        "scorer_id": {"type": "string"},
        "scoring_blinded": {"type": "boolean"},
        "scoring_notes": {"type": "string"}
      }
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "outcome_source", "outcome_date"],
      "properties": {
        "outcome": {"enum": ["collapse", "major_scandal", "distress", "stable"]},
        "outcome_source": {"type": "string", "minLength": 1},
        "outcome_date": {"type": ["string", "null"], "format": "date"},
        "notes": {"type": "string"}
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "included_in_final_analysis": {"type": "boolean", "default": true},
        "exclusion_reason": {"type": ["string", "null"]},
        "matched_control_sample_id": {"type": ["string", "null"]},
        "status": {"enum": ["pending", "included", "excluded"]}
      }
    }
  }
}
