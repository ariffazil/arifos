# AGENT ZERO — ai.arif-fazil.com
# Autonomous agent interface. MCP server exposed for arifOS forge integration.
# Login: https://ai.arif-fazil.com | ROOT_PASSWORD set in compose
# MCP endpoint: ai.arif-fazil.com:9000 (streamable HTTP MCP)
# ═══════════════════════════════════════════════════════════════════════════════
ai.arif-fazil.com {
	import tls_origin
	encode zstd gzip

	# Web UI + MCP (agent-zero Flask on port 80 → host 50001)
	# MCP endpoint: /mcp/t-{token}/sse and /mcp/t-{token}/messages/
	handle /api/* {
		reverse_proxy 127.0.0.1:50001 {
			header_up Host ai.arif-fazil.com
		}
	}
	handle /mcp/* {
		reverse_proxy 127.0.0.1:50001 {
			header_up Host ai.arif-fazil.com
		}
	}
	handle /* {
		reverse_proxy 127.0.0.1:50001 {
			header_up Host ai.arif-fazil.com
		}
	}
}

