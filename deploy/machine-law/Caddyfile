mcp.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/mcp

    handle /mcp* {
        reverse_proxy arifosmcp:8080
    }
    handle /health {
        reverse_proxy arifosmcp:8080
    }
    handle /tools {
        reverse_proxy arifosmcp:8080
    }
    handle /metadata {
        reverse_proxy arifosmcp:8080
    }
    handle /ready {
        reverse_proxy arifosmcp:8080
    }

    # Static surfaces (Human readable)
    handle / {
        file_server
    }
    handle /privacy* {
        file_server
    }
    handle /webmcp* {
        file_server
    }
    handle /app* {
        file_server
    }
    handle /apps* {
        file_server
    }

    # Fallback
    handle {
        reverse_proxy arifosmcp:8080
    }
}

arifosmcp.arif-fazil.com {
    import tls_origin
    redir https://mcp.arif-fazil.com{uri} permanent
}

