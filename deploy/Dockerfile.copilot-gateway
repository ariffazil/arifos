# Dockerfile.copilot-gateway — Lean Python image for Copilot Governance Gateway
# DITEMPA BUKAN DIBERI — Forged, Not Given
# Stage: build → runtime
# Built image: ghcr.io/ariffazil/copilot-gateway:latest

FROM python:3.12-slim AS build

WORKDIR /app

# Install runtime deps only
RUN pip install --no-cache-dir --break-system-packages \
    fastapi==0.115.0 \
    uvicorn[standard]==0.34.0 \
    pydantic==2.10.5

FROM python:3.12-slim AS runtime

WORKDIR /app

# No root — run as non-root user
RUN useradd --create-home --shell /bin/bash --uid 1000 arifos

# Copy installed packages from build
COPY --from=build /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=build /usr/local/bin /usr/local/bin

# Runtime deps (only what's needed for gateway)
RUN pip install --no-cache-dir --break-system-packages --target /usr/local/lib/python3.12/site-packages \
    fastapi==0.115.0 \
    uvicorn[standard]==0.34.0 \
    pydantic==2.10.5

# Create app directory
RUN mkdir -p /app/arifosmcp/runtime
USER arifos

# Default: stay alive (will be overridden by compose command)
CMD ["python", "-c", "import time; import signal; signal.signal(signal.SIGTERM, lambda *a: exit(0)); time.sleep(86400)"]
