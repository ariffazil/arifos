# arifOS MCP — AF-FORGE Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy to .env and fill in actual values. DO NOT commit .env to git.

# ─── Build Metadata ───────────────────────────────────────────────────────────
ARIFOS_BUILD_SHA=dev
ARIFOS_BUILD_TIME=2026-04-06T00:00:00Z
ARIFOS_APP_VERSION=2026.04.06

# ─── Server Configuration ─────────────────────────────────────────────────────
ARIFOS_MCP_TRANSPORT=http
ARIFOS_MCP_HOST=0.0.0.0
ARIFOS_MCP_PORT=3000

# ─── Federation Endpoint ──────────────────────────────────────────────────────
ARIFOS_VPS_URL=https://arifos.federation

# ─── Secrets (888 HOLD - Use Docker secrets or mounted files in production) ───
# ARIFOS_GOVERNANCE_SECRET=path:/run/secrets/governance_secret
# ARIFOS_BLS_SIGNER_ENABLED=false

# ─── Optional Backends ────────────────────────────────────────────────────────
# QDRANT_URL=http://qdrant:6333
# REDIS_URL=redis://redis:6379
