# arifOS Sovereign Caddyfile
# DITEMPA BUKAN DIBERI
# 3 Main Sites: arif-fazil.com | arifos.arif-fazil.com | aaa.arif-fazil.com
# Federation MCP: arifos (13) | geox (28) | wealth (40+) | well (30+)
# Last reconcile: 2026-05-01 — FULL SWEEP: root→dist, apex+wiki merged, handle_path fixed

{
    admin unix//var/run/caddy-admin.sock
    email arif@arif-fazil.com
}

(tls_origin) {
    tls /data/cloudflare-origin/cert.pem /data/cloudflare-origin/key.pem
    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

(shared_assets) {
    handle /_shared/* {
        root * /var/www/html/_shared
        file_server
    }
}

(cors_public) {
    header Access-Control-Allow-Origin *
    header Access-Control-Allow-Methods "GET, POST, OPTIONS"
}

# ═══════════════════════════════════════════════════════════════════════
# MAIN SITE 1 — Ψ HUMAN SURFACE
# arif-fazil.com | www.arif-fazil.com
# Root: /var/www/html/arif (static HTML — no React build)
# Sub-pages: /apex | /wiki | /888 | /000 | /999 | /.well-known
# ═══════════════════════════════════════════════════════════════════════
www.arif-fazil.com {
    import tls_origin
    redir https://arif-fazil.com{uri} permanent
}

arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/arif

    # ACME challenge + identity
    handle_path /.well-known/* {
        root * /var/www/html/arif/.well-known
        file_server
    }

    # Constitutional genesis
    handle_path /000/* {
        root * /var/www/html/arif/000
        try_files {path} /index.html
        file_server
    }

    # Constitutional validation
    handle_path /999/* {
        root * /var/www/html/arif/999
        try_files {path} /index.html
        file_server
    }

    # AGI lane (888)
    handle_path /888/* {
        root * /var/www/html/arif/888
        try_files {path} /index.html
        file_server
    }

    # APEX theory
    handle_path /apex/* {
        root * /var/www/html/apex
        try_files {path} /index.html
        file_server
    }

    # Ω-Wiki
    handle_path /wiki/* {
        root * /var/www/html/wiki
        try_files {path} /index.html
        file_server
    }

    handle {
        try_files {path} {path}/index.html /index.html
        file_server
    }
}

# ═══════════════════════════════════════════════════════════════════════
# MAIN SITE 2 — Ω ARIFOS OBSERVATORY
# arifos.arif-fazil.com
# Root: /var/www/html/arifos
# MCP: /mcp*, /health, /tools, /sse → arifosmcp:8080
# Ω-Wiki: /wiki/*
# ═══════════════════════════════════════════════════════════════════════
arifos.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/arifos

    handle_path /.well-known/* {
        root * /var/www/html/arifos/.well-known
        file_server
    }

    handle /mcp* {
        reverse_proxy arifosmcp:8080
    }
    handle /health {
        reverse_proxy arifosmcp:8080
    }
    handle /tools {
        reverse_proxy arifosmcp:8080
    }
    handle /tools.json {
        reverse_proxy arifosmcp:8080
    }
    handle /sse* {
        reverse_proxy arifosmcp:8080
    }
    handle /api/status {
        reverse_proxy arifosmcp:8080
    }

    # Agent discovery + WebMCP routes (P0 fix)
    handle /agent-card.json {
        root * /var/www/html/arifos
        file_server
    }
    handle /a2a/discovery {
        root * /var/www/html/arifos/a2a
        try_files {path} /discovery.json
        file_server
    }
    handle /llms.txt {
        root * /var/www/html/arifos
        file_server
    }
    handle /llms.json {
        root * /var/www/html/arifos
        file_server
    }
    handle /llms-full.txt {
        root * /var/www/html/arifos
        file_server
    }
    handle /webmcp {
        reverse_proxy arifosmcp:8080 {
            flush_interval 100ms
        }
    }
    # Ω-Wiki merged from wiki.arif-fazil.com
    handle_path /wiki/* {
        root * /var/www/html/wiki
        try_files {path} /index.html
        file_server
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}

