# arifOS Sovereign Caddyfile — 3-Surface Architecture
# DITEMPA BUKAN DIBERI
# Hardening: Transparent Sovereign (V10 FIXED)

{
    admin unix//var/run/caddy-admin.sock
    email arif@arif-fazil.com
}

# ─── CONSTITUTIONAL HEADERS MACRO ──────────────────────────────────────────────
(constitutional_headers) {
    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://mcp.arif-fazil.com https://arifos.arif-fazil.com;"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-origin"
    }
}

(tls_origin) {
    tls /data/cloudflare-origin/cert.pem /data/cloudflare-origin/key.pem
    import constitutional_headers
}

(shared_assets) {
    handle /_shared/* {
        root * /var/www/html/_shared
        file_server
    }
}

# ─── Ψ HUMAN SURFACE ───────────────────────────────────────────────────────────
arif-fazil.com, www.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/arif
    handle {
        try_files {path} /index.html
        file_server
    }
}

# ─── Δ MACHINE SURFACE ─────────────────────────────────────────────────────────
mcp.arif-fazil.com {
    import tls_origin
    encode zstd gzip

    handle /health {
        reverse_proxy http://arifosmcp:8080
    }

    handle /mcp* {
        reverse_proxy http://arifosmcp:8080 {
            flush_interval -1
        }
    }

    handle /metrics/json {
        reverse_proxy http://arifosmcp:8080
    }

    handle {
        respond "arifOS MCP API" 200
    }
}

# ─── Ω INTELLIGENCE SURFACE ────────────────────────────────────────────────────
arifos.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/arifos

    handle /capability {
        reverse_proxy http://arifosmcp:8080
    }

    handle /000/* {
        reverse_proxy http://arifosmcp:8080
    }

    handle /999/* {
        reverse_proxy http://arifosmcp:8080
    }

    handle /tools* {
        reverse_proxy http://arifosmcp:8080
    }

    handle /capability {
        reverse_proxy http://arifosmcp:8080
    }

    handle /mcp* {
        reverse_proxy http://arifosmcp:8080 {
            flush_interval -1
        }
    }

    handle /health {
        reverse_proxy http://arifosmcp:8080
    }

    handle /llms.txt {
        reverse_proxy http://arifosmcp:8080
    }

    handle /.well-known/mcp/server-card.json {
        reverse_proxy http://arifosmcp:8080
    }

    handle /ops/* {
        file_server
    }

    handle / {
        file_server
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}

