# arifOS Sovereign Caddyfile
# v2026.04.30-REMEDIATED-V17

{
    admin unix//var/run/caddy-admin.sock
    email arif@arif-fazil.com
}

(constitutional_headers) {
    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://mcp.arif-fazil.com https://arifos.arif-fazil.com;"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
        Cross-Origin-Opener-Policy "same-origin"
        Cross-Origin-Resource-Policy "same-origin"
    }
}

(sovereign_gate) {
    @blocked {
        not remote_ip 2a02:4780:5e:dbf6::1 127.0.0.1 ::1
    }
    respond @blocked "403 Forbidden — Sovereign IP Only" 403
}

(tls_origin) {
    tls /data/cloudflare-origin/cert.pem /data/cloudflare-origin/key.pem
    import constitutional_headers
}

(shared_assets) {
    handle /_shared/* {
        root * /var/www/html/_shared
        file_server
    }
}

arif-fazil.com {
    import tls_origin
    import shared_assets
    root * /var/www/html/arif
    handle /.well-known/did.json {
        file_server
    }
    handle /000 {
        file_server
    }
    handle /000/* {
        file_server
    }
    handle /999 {
        file_server
    }
    handle /999/* {
        file_server
    }
    handle {
        try_files {path} /index.html
        file_server
    }
}

www.arif-fazil.com {
    import tls_origin
    redir https://arif-fazil.com{uri} permanent
}

mcp.arif-fazil.com {
    import tls_origin
    handle /mcp/* {
        reverse_proxy http://arifosmcp:8080 {
            flush_interval -1
        }
    }
    handle /health {
        reverse_proxy http://arifosmcp:8080
    }
    handle /metrics/json {
        import sovereign_gate
        reverse_proxy http://arifosmcp:8080
    }
    handle {
        respond "arifOS MCP API" 200
    }
}

arifos.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/arifos
    handle /000/* {
        file_server
    }
    handle /999/* {
        file_server
    }
    handle /llms.txt {
        file_server
    }
    handle /ops/* {
        import sovereign_gate
        file_server
    }
    handle /mcp/* {
        reverse_proxy http://arifosmcp:8080 {
            flush_interval -1
        }
    }
    handle /health {
        reverse_proxy http://arifosmcp:8080
    }
    handle /tools {
        reverse_proxy http://arifosmcp:8080
    }
    handle /tools.json {
        reverse_proxy http://arifosmcp:8080
    }
    handle /tools/* {
        reverse_proxy http://arifosmcp:8080
    }
    handle /capability {
        reverse_proxy http://arifosmcp:8080
    }
    handle /.well-known/mcp/server-card.json {
        file_server
    }
    handle /.well-known/mcp/* {
        reverse_proxy http://arifosmcp:8080
    }
    handle {
        try_files {path} /index.html
        file_server
    }
}

