# geox.arif-fazil.com
# ═══════════════════════════════════════════════════════════════
# geox.arif-fazil.com — Earth intelligence MCP
# ═══════════════════════════════════════════════════════════════
geox.arif-fazil.com {
	encode zstd gzip
	root * /var/www/html/geox

	header {
		Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-cf-ray
		-cf-request-id
		-server
		Access-Control-Allow-Origin *
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
	}

	@las_files path *.las
	handle @las_files {
		header Content-Type application/octet-stream
		file_server
	}

	handle /panels/* {
		root * /data/geox_panels
		file_server
		header Cache-Control "no-store, no-cache"
	}

	handle /mcp* {
		reverse_proxy 127.0.0.1:8081 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			flush_interval -1
			transport http {
				dial_timeout 10s
				read_timeout 30s
			}
		}
	}
	handle /tools {
		reverse_proxy 127.0.0.1:8081 {
			transport http {
				dial_timeout 5s
			}
		}
	}
	handle /tools.json {
		reverse_proxy 127.0.0.1:8081 {
			transport http {
				dial_timeout 5s
			}
		}
	}
	handle /health {
		reverse_proxy 127.0.0.1:8081 {
			transport http {
				dial_timeout 5s
				read_timeout 10s
			}
		}
	}
	handle /ready {
		reverse_proxy 127.0.0.1:8081 {
			transport http {
				dial_timeout 5s
				read_timeout 10s
			}
		}
	}
	handle /status {
		reverse_proxy 127.0.0.1:8081 {
			transport http {
				dial_timeout 5s
				read_timeout 10s
			}
		}
	}
	handle /sse* {
		reverse_proxy 127.0.0.1:8081 {
			flush_interval -1
			transport http {
				dial_timeout 5s
				read_timeout 30s
			}
		}
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}

