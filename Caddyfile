# arifOS Sovereign Caddyfile — SIMPLIFIED
# DITEMPA BUKAN DIBERI
# Fully public: Let's Encrypt auto-HTTPS, no Cloudflare token needed
# Cloudflare just handles DNS (grey cloud) — Caddy handles TLS directly
#
# PUBLIC ACCESSIBLE:
#   arif-fazil.com        → static hub
#   arifos.arif-fazil.com → MCP + Observatory
#   geox.arif-fazil.com   → GEOX MCP
#   wealth.arif-fazil.com → WEALTH MCP
#   well.arif-fazil.com   → WELL MCP
#   aaa.arif-fazil.com    → AAA cockpit

{
    admin unix//var/run/caddy-admin.sock
    email arif@arif-fazil.com
}

# ═══════════════════════════════════════════════════════════════
# arif-fazil.com — Human surface
# ═══════════════════════════════════════════════════════════════
arif-fazil.com, www.arif-fazil.com {
    encode zstd gzip
    root * /var/www/html/arif

    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove Cloudflare headers so bots/agents see clean origin
        -cf-ray
        -cf-request-id
        -server
    }

    handle_path /.well-known/* {
        root * /var/www/html/arif/.well-known
        file_server
    }
    handle_path /000/* {
        root * /var/www/html/arif/000
        try_files {path} /index.html
        file_server
    }
    handle_path /999/* {
        root * /var/www/html/arif/999
        try_files {path} /index.html
        file_server
    }
    handle_path /888/* {
        root * /var/www/html/arif/888
        try_files {path} /index.html
        file_server
    }
    handle_path /apex/* {
        root * /var/www/html/apex
        try_files {path} /index.html
        file_server
    }
    handle_path /wiki/* {
        root * /var/www/html/wiki
        try_files {path} /index.html
        file_server
    }
    handle {
        try_files {path} {path}/index.html /index.html
        file_server
    }
}

# ═══════════════════════════════════════════════════════════════
# arifos.arif-fazil.com — Constitutional kernel + Observatory
# ═══════════════════════════════════════════════════════════════
arifos.arif-fazil.com {
    encode zstd gzip
    root * /var/www/html/arifos

    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -cf-ray
        -cf-request-id
        -server
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
    }

    handle /.well-known/* {
        root * /var/www/html/arifos/.well-known
        file_server
    }
    handle /mcp* {
        reverse_proxy 127.0.0.1:8080 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            flush_interval -1
        }
    }
    handle /health {
        reverse_proxy 127.0.0.1:8080
    }
    handle /tools {
        reverse_proxy 127.0.0.1:8080
    }
    handle /tools.json {
        reverse_proxy 127.0.0.1:8080
    }
    handle /sse* {
        reverse_proxy 127.0.0.1:8080 {
            flush_interval -1
        }
    }
    handle /api/status {
        reverse_proxy 127.0.0.1:8080
    }
    handle /api/federation-probe {
        reverse_proxy 127.0.0.1:8080
    }
    handle /agent-card.json {
        root * /var/www/html/arifos
        file_server
    }
    handle /a2a/discovery {
        root * /var/www/html/arifos/a2a
        try_files {path} /discovery.json
        file_server
    }
    handle /llms.txt {
        root * /var/www/html/arifos
        file_server
    }
    handle /llms.json {
        root * /var/www/html/arifos
        file_server
    }
    handle /llms-full.txt {
        root * /var/www/html/arifos
        file_server
    }
    handle /webmcp {
        reverse_proxy 127.0.0.1:8080 {
            flush_interval 100ms
        }
    }
    handle /wiki/* {
        root * /var/www/html/wiki
        try_files {path} /index.html
        file_server
    }
    handle {
        try_files {path} /index.html
        file_server
    }
}

# ═══════════════════════════════════════════════════════════════
# geox.arif-fazil.com — Earth intelligence MCP
# ═══════════════════════════════════════════════════════════════
geox.arif-fazil.com {
    encode zstd gzip
    root * /var/www/html/geox

    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -cf-ray
        -cf-request-id
        -server
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
    }

    @las_files path *.las
    handle @las_files {
        header Content-Type application/octet-stream
        file_server
    }

    handle /panels/* {
        root * /data/geox_panels
        file_server
        header Cache-Control "no-store, no-cache"
    }

    handle /mcp* {
        reverse_proxy 127.0.0.1:8081 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            flush_interval -1
            transport http {
                dial_timeout 10s
                read_timeout 30s
            }
        }
    }
    handle /health {
        reverse_proxy 127.0.0.1:8081 {
            transport http {
                dial_timeout 5s
                read_timeout 10s
            }
        }
    }
    handle /ready {
        reverse_proxy 127.0.0.1:8081 {
            transport http {
                dial_timeout 5s
                read_timeout 10s
            }
        }
    }
    handle /status {
        reverse_proxy 127.0.0.1:8081 {
            transport http {
                dial_timeout 5s
                read_timeout 10s
            }
        }
    }
    handle /sse* {
        reverse_proxy 127.0.0.1:8081 {
            flush_interval -1
            transport http {
                dial_timeout 5s
                read_timeout 30s
            }
        }
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}

