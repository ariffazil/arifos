# arifOS Sovereign Caddyfile — 3-Surface Architecture
# DITEMPA BUKAN DIBERI
# Ψ Human Surface | Δ Machine Surface | Ω Intelligence Surface
# Reconcile: 2026-04-27

{
    admin unix//var/run/caddy-admin.sock
    email arif@arif-fazil.com
}

(tls_origin) {
    tls /data/cloudflare-origin/cert.pem /data/cloudflare-origin/key.pem
    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

(shared_assets) {
    handle /_shared/* {
        root * /var/www/html/_shared
        file_server
    }
}

# ─── Ψ HUMAN SURFACE ───────────────────────────────────────────────────────────
# arif-fazil.com — Personal anchor: human portfolio, wisdom wall, verification room
arif-fazil.com, www.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip

    root * /var/www/html/arif

    # Sub-pages
    handle /000 {
        redir /000 /000/
    }
    handle /000/* {
        root * /var/www/html/arif/000
        file_server
        try_files {path} /index.html
    }
    handle /999 {
        redir /999 /999/
    }
    handle /999/* {
        root * /var/www/html/arif/999
        file_server
        try_files {path} /index.html
    }
    handle /proof/* {
        root * /var/www/html/arif/proof
        file_server
    }
    handle /.well-known/* {
        root * /var/www/html/arif/.well-known
        file_server
    }

    handle /llms.txt {
        file_server
    }
    handle /llms-full.txt {
        file_server
    }

    handle {
        file_server
        try_files {path} /index.html
    }
}

# ─── Δ MACHINE SURFACE ─────────────────────────────────────────────────────────
# mcp.arif-fazil.com — MCP gateway: landing page + JSON-RPC proxy
mcp.arif-fazil.com {
    import tls_origin
    encode zstd gzip

    root * /var/www/html/mcp

    # MCP JSON-RPC → arifosmcp (fixed: was 3000, actual port is 8080)
    handle /mcp* {
        reverse_proxy arifosmcp:8080
    }
    handle /health {
        reverse_proxy arifosmcp:8080
    }
    handle /tools {
        reverse_proxy arifosmcp:8080
    }
    handle /metadata {
        reverse_proxy arifosmcp:8080
    }
    handle /ready {
        reverse_proxy arifosmcp:8080
    }
    handle /.well-known/mcp* {
        reverse_proxy arifosmcp:8080
    }

    # AAA A2A gateway
    handle /a2a/* {
        reverse_proxy aaa-a2a:3001
    }

    # Human-readable surfaces
    handle /llms.txt {
        file_server
    }
    handle /llms-full.txt {
        file_server
    }
    handle /privacy* {
        file_server
    }
    handle /app* {
        file_server
    }
    handle /apps* {
        file_server
    }
    handle /webmcp* {
        file_server
    }
    handle /command-center* {
        file_server
    }

    handle {
        file_server
        try_files {path} /index.html
    }
}

# arifOS MCP alias
arifosmcp.arif-fazil.com {
    import tls_origin
    redir https://mcp.arif-fazil.com{uri} permanent
}

# ─── Ω INTELLIGENCE SURFACE ────────────────────────────────────────────────────
# arifOS.arif-fazil.com — Federation hub: arifOS + geox + wealth + forge
arifos.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip

    root * /var/www/html/arifos

    # GEOX Earth Intelligence sub-section
    handle /geox* {
        root * /var/www/html/geox
        handle /geox/mcp* {
            reverse_proxy geox:8081
        }
        handle /geox/health {
            reverse_proxy geox:8081
        }
        handle {
            file_server
            try_files {path} /index.html
        }
    }

    # WEALTH Capital Intelligence sub-section
    handle /wealth* {
        root * /var/www/html/wealth
        handle /wealth/mcp* {
            reverse_proxy wealth-organ:8000
        }
        handle /wealth/health {
            reverse_proxy wealth-organ:8000
        }
        handle /wealth/api* {
            reverse_proxy wealth-organ:8000
        }
        handle /wealth/ready {
            reverse_proxy wealth-organ:8000
        }
        handle {
            file_server
            try_files {path} /index.html
        }
    }

    # FORGE Execution Substrate sub-section
    handle /forge* {
        root * /var/www/html/forge
        file_server
        try_files {path} /index.html
    }

    # AAA Control Plane sub-section
    handle /aaa* {
        root * /var/www/html/aaa
        handle /aaa/a2a/* {
            reverse_proxy aaa-a2a:3001
        }
        handle {
            file_server
            try_files {path} /index.html
        }
    }

    # WIKI Knowledge Mesh sub-section
    handle /wiki* {
        root * /var/www/html/wiki
        file_server
        try_files {path} /index.html
    }

    # WAW Words and Works sub-section
    handle /waw* {
        root * /var/www/html/waw
        file_server
        try_files {path} /index.html
    }

    handle {
        file_server
        try_files {path} /index.html
    }
}

