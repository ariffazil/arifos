# ═══════════════════════════════════════════════════════════════════════
# FEDERATION MCP — GEOX
# geox.arif-fazil.com
# ChatGPT registered here — DO NOT MOVE
# ═══════════════════════════════════════════════════════════════════════
geox.arif-fazil.com {
    import tls_origin
    import shared_assets
    encode zstd gzip
    root * /var/www/html/geox

    # Serve .las files with correct content-type
    @las_files {
        path *.las
    }
    handle @las_files {
        header Content-Type "application/octet-stream"
        file_server
    }

    # GEOX artifact download — PNG/CSV panels
    handle /panels/* {
        root * /data/geox_panels
        file_server
        header Cache-Control "no-store, no-cache"
    }

    # GEOX MCP — proxy /mcp to geox_eic, FastMCP serves at root
    handle /mcp* {
        reverse_proxy 172.19.0.5:8081 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up Accept "text/event-stream, application/json"
            flush_interval -1
        }
    }
    handle /health {
        import cors_public
        reverse_proxy 172.19.0.5:8081
    }
    handle /ready {
        import cors_public
        reverse_proxy 172.19.0.5:8081
    }
    handle /status {
        import cors_public
        reverse_proxy 172.19.0.5:8081
    }
    handle /sse* {
        reverse_proxy 172.19.0.5:8081
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}

