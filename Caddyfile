# arifOS Sovereign Caddyfile — SIMPLIFIED
# DITEMPA BUKAN DIBERI
# Fully public: Let's Encrypt auto-HTTPS, no Cloudflare token needed
# Cloudflare just handles DNS (grey cloud) — Caddy handles TLS directly
#
# PUBLIC ACCESSIBLE:
#   arif-fazil.com        → static hub
#   arifos.arif-fazil.com → MCP + Observatory
#   geox.arif-fazil.com   → GEOX MCP
#   wealth.arif-fazil.com → WEALTH MCP
#   well.arif-fazil.com   → WELL MCP
#   aaa.arif-fazil.com    → AAA cockpit
{
	admin unix//var/run/caddy-admin.sock
	email arif@arif-fazil.com
}

# ═══════════════════════════════════════════════════════════════
# arif-fazil.com — Human surface
# ═══════════════════════════════════════════════════════════════
arif-fazil.com, www.arif-fazil.com {
	encode zstd gzip
	root * /var/www/html/arif

	header {
		Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Remove Cloudflare headers so bots/agents see clean origin
		-cf-ray
		-cf-request-id
		-server
	}

	handle_path /.well-known/* {
		root * /var/www/html/arif/.well-known
		file_server
	}
	handle_path /000/* {
		root * /var/www/html/arif/000
		try_files {path} /index.html
		file_server
	}
	handle_path /999/* {
		root * /var/www/html/arif/999
		try_files {path} /index.html
		file_server
	}
	handle_path /888/* {
		root * /var/www/html/arif/888
		try_files {path} /index.html
		file_server
	}
	handle_path /apex/* {
		root * /var/www/html/apex
		try_files {path} /index.html
		file_server
	}
	handle_path /wiki/* {
		root * /var/www/html/wiki
		try_files {path} /index.html
		file_server
	}
	handle {
		try_files {path} {path}/index.html /index.html
		file_server
	}
}

# ═══════════════════════════════════════════════════════════════
# arifos.arif-fazil.com — Constitutional kernel + Observatory
# ═══════════════════════════════════════════════════════════════
arifos.arif-fazil.com {
	encode zstd gzip
	root * /var/www/html/arifos

	header {
		Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-cf-ray
		-cf-request-id
		-server
	}

	# P2: Bot scanner paths → cheap 404
	@badpaths {
		path /.env /.git/* /wp-login /phpmyadmin /admin /swagger /api-docs /server-status /debug
	}
	handle @badpaths {
		respond "Not found" 404
	}

	# P1: Metrics → arifOS (before SPA fallback swallows them)
	@metrics {
		path /metrics /metrics/json
	}
	handle @metrics {
		reverse_proxy 127.0.0.1:8080 {
			header_down -Access-Control-Allow-Origin
		}
	}

	handle /.well-known/* {
		root * /var/www/html/arifos/.well-known
		file_server
	}

	handle /mcp* {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_down -Access-Control-Allow-Origin
			flush_interval -1
		}
	}

	handle /health {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080 {
			header_down -Access-Control-Allow-Origin
		}
	}

	handle /tools {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080 {
			header_down -Access-Control-Allow-Origin
		}
	}

	handle /tools.json {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080
	}

	handle /sse* {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080 {
			header_down -Access-Control-Allow-Origin
			flush_interval -1
		}
	}

	handle /api/status {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080 {
			header_down -Access-Control-Allow-Origin
		}
	}

	handle /api/federation-probe {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080
	}

	handle /api/* {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080
	}

	handle /components {
		reverse_proxy 127.0.0.1:8080
	}

	handle /capability {
		reverse_proxy 127.0.0.1:8080
	}

	handle /version {
		reverse_proxy 127.0.0.1:8080
	}

	handle /runtime_fingerprint {
		reverse_proxy 127.0.0.1:8080
	}

	handle /openapi.json {
		reverse_proxy 127.0.0.1:8080
	}

	handle /registry.json {
		reverse_proxy 127.0.0.1:8080
	}

	handle /ready {
		reverse_proxy 127.0.0.1:8080
	}

	handle /discovery {
		reverse_proxy 127.0.0.1:8080
	}

	handle /agent-card.json {
		root * /var/www/html/arifos
		file_server
	}

	handle /a2a/discovery {
		root * /var/www/html/arifos/a2a
		try_files {path} /discovery.json
		file_server
	}

	handle /llms.txt {
		root * /var/www/html/arifos
		file_server
	}

	handle /llms.json {
		root * /var/www/html/arifos
		file_server
	}

	handle /llms-full.txt {
		root * /var/www/html/arifos
		file_server
	}

	handle /webmcp {
		header Access-Control-Allow-Origin "https://arifos.arif-fazil.com https://arif-fazil.com https://aaa.arif-fazil.com"
		header Access-Control-Allow-Methods "POST, GET, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		reverse_proxy 127.0.0.1:8080 {
			header_down -Access-Control-Allow-Origin
			flush_interval 100ms
		}
	}

	handle /wiki/* {
		root * /var/www/html/wiki
		try_files {path} /index.html
		file_server
	}

	# P1: CSP for SPA only
	handle {
		header {
			Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://arifos.arif-fazil.com https://mcp.arif-fazil.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self';"
		}
		try_files {path} /index.html
		file_server
	}
}

