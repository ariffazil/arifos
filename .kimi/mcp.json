{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Kimi CLI MCP Configuration for arifOS v55.5 - Aligned with 9 Canonical Tools",
  "mcpServers": {
    "aaa-mcp": {
      "command": "C:\\Users\\User\\arifOS\\.venv\\Scripts\\python.exe",
      "args": ["-m", "aaa_mcp", "stdio"],
      "cwd": "C:/Users/User/arifOS",
      "env": {
        "PYTHONPATH": "C:/Users/User/arifOS",
        "ARIFOS_CONSTITUTIONAL_MODE": "AAA",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1",
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "BROWSERBASE_API_KEY": "${BROWSERBASE_API_KEY}"
      },
      "disabled": false,
      "alwaysAllow": [
        "init_gate",
        "agi_sense",
        "agi_think",
        "agi_reason",
        "asi_empathize",
        "asi_align",
        "apex_verdict",
        "reality_search",
        "vault_seal"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@latest", "C:/Users/User/arifOS"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "read_file",
        "read_multiple_files",
        "write_file",
        "edit_file",
        "list_directory",
        "directory_tree",
        "search_files",
        "get_file_info"
      ]
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"],
      "cwd": "C:/Users/User/arifOS",
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "git_status",
        "git_diff",
        "git_diff_staged",
        "git_log",
        "git_branch",
        "git_add",
        "git_commit"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@latest"],
      "env": {
        "MEMORY_FILE_PATH": "C:/Users/User/arifOS/.kimi/memory.json"
      },
      "disabled": false,
      "alwaysAllow": [
        "read_graph",
        "search_nodes",
        "create_entities",
        "create_relations",
        "add_observations"
      ]
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server@latest"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "PERPLEXITY_TIMEOUT_MS": "300000"
      },
      "disabled": false,
      "alwaysAllow": [
        "perplexity_search",
        "perplexity_ask",
        "perplexity_research",
        "perplexity_reason"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@latest"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "sequentialthinking"
      ]
    }
  }
}
