{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifOS.context_packet.forge",
  "context_packet_version": "1.0.0",
  "tool_id": "arifos.forge",
  "stage": "FORGE_010",
  "stage_order": 9,
  "desc": "Execution bridge",
  "trinity": "Δ",
  "trinity_name": "Discernment",
  "uri": "/arifOS/runtime/code_engine",
  "backing_tool": "code_engine",
  "role": "executor",
  "role_description": "Hardened execution bridge with attestation",
  "modes": ["execute"],
  "default_mode": "execute",
  "purpose": "Bridge governed decisions to controlled execution environment. The ONLY path for state mutation. Requires SEAL verdict + HMAC-signed envelope.",
  "when_to_use": [
    "After judge renders SEAL verdict",
    "Need to execute approved action",
    "State mutation is required",
    "Action passed all governance gates"
  ],
  "when_not_to_use": [
    "NEVER use without SEAL verdict - HARD STOP",
    "NEVER use without HMAC attestation - HARD STOP",
    "Do not use for thinking - that's arifos.mind",
    "Do not use for retrieval - that's arifos.memory",
    "Do not use for safety check - that's arifos.heart"
  ],
  "not_job": [
    "Not a decision maker - executes decisions",
    "Not a safety validator - uses pre-verified input",
    "Not an open execution environment - governed only",
    "Not available without proper attestation"
  ],
  "inputs": {
    "mode": {
      "type": "string",
      "enum": ["execute"],
      "description": "execute: perform attested action"
    },
    "required_payload": {
      "execution_envelope": {
        "type": "object",
        "properties": {
          "query_hash": "string - Hash of original query",
          "verdict": "string - Must be SEAL",
          "actor_id": "string - Who is executing",
          "timestamp": "string - ISO timestamp",
          "signature": "string - HMAC-SHA256"
        },
        "required": ["query_hash", "verdict", "actor_id", "timestamp", "signature"]
      }
    },
    "optional_payload": {
      "action_type": "string - spawn|write|send|call",
      "target": "string - Execution target",
      "constraints": "object - Execution limits"
    }
  },
  "outputs": {
    "primary": "execution_result",
    "shape": {
      "success": "boolean",
      "result": "object - Execution output",
      "attestation": "object - LAYER_3 proof",
      "side_effects": "object[] - What changed",
      "execution_log": "string[] - Audit trail"
    }
  },
  "state_behavior": {
    "reads_state": true,
    "writes_state": true,
    "external_side_effects": true,
    "requires_attestation": true,
    "hardened": true
  },
  "authority_model": {
    "advisory_only": false,
    "executes_only": true,
    "requires_seal": true,
    "requires_attestation": true,
    "cannot_override": true,
    "hard_stop_on_invalid": true
  },
  "context_contract": {
    "consumes": [
      "SEAL verdict",
      "HMAC attestation",
      "execution specification",
      "session context"
    ],
    "emits": [
      "execution result",
      "attestation proof",
      "side effect log",
      "telemetry for vault"
    ]
  },
  "routing_hints": {
    "upstream": ["arifos.judge"],
    "downstream": ["arifos.vault"],
    "mandatory_after": ["888_JUDGE"],
    "typical_flow": ["888_JUDGE (SEAL) → FORGE_010 → 999_VAULT"]
  },
  "governance_requirements": {
    "risk_tier": "critical",
    "dry_run_allowed": true,
    "requires_seal": true,
    "requires_attestation": true,
    "layer_3_protection": true
  },
  "chatgpt_guidance": {
    "plain_english": "Use this ONLY to execute actions that have passed ALL governance gates. It requires a SEAL verdict and cryptographic proof. This is the ONLY way to change state.",
    "key_phrases": ["execute", "run", "deploy", "write file", "spawn process"],
    "ask_before_use_if": [
      "you have a SEAL verdict",
      "you have the HMAC attestation envelope",
      "all upstream stages completed"
    ],
    "do_not_assume": [
      "you can use forge directly - you cannot",
      "dry_run false works without attestation - it does not",
      "forge is available for testing - production requires container"
    ],
    "ideal_prompt_shape": {
      "mode": "execute",
      "execution_envelope": {
        "query_hash": "sha256:abc123...",
        "verdict": "SEAL",
        "actor_id": "ARIF",
        "timestamp": "2026-04-06T00:00:00Z",
        "signature": "hmac:xyz789..."
      },
      "action_type": "write",
      "target": "/project/config.yaml"
    }
  }
}
