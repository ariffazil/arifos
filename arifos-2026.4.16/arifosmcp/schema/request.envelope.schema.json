{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifOS.request.v1",
  "title": "arifOS Unified Request Envelope",
  "description": "Standardized input wrapper for all arifOS tool calls. Provides session continuity, governance context, and telemetry.",
  "version": "1.0.0",
  "type": "object",
  "required": ["tool", "stage", "mode", "session", "payload"],
  "properties": {
    "tool": {
      "type": "string",
      "description": "Tool being invoked",
      "enum": ["arifos.init", "arifos.sense", "arifos.mind", "arifos.route", "arifos.memory", "arifos.heart", "arifos.ops", "arifos.judge", "arifos.vault", "arifos.forge"]
    },
    "stage": {
      "type": "string",
      "description": "Stage of governance pipeline",
      "enum": ["000_INIT", "111_SENSE", "333_MIND", "444_ROUTER", "555_MEMORY", "666_HEART", "777_OPS", "888_JUDGE", "999_VAULT", "FORGE_010"]
    },
    "mode": {
      "type": "string",
      "description": "Operation mode for the tool"
    },
    "session": {
      "type": "object",
      "description": "Session continuity context",
      "required": ["session_id", "actor_id"],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 8,
          "description": "Unique session identifier"
        },
        "actor_id": {
          "type": "string",
          "description": "Identity of the calling entity"
        },
        "declared_name": {
          "type": "string",
          "description": "Human-readable actor name"
        },
        "conversation_id": {
          "type": "string",
          "description": "Parent conversation identifier"
        },
        "turn_id": {
          "type": "string",
          "description": "Current turn within conversation"
        },
        "initialized_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "intent": {
      "type": "object",
      "description": "Human purpose and goals",
      "properties": {
        "task": {
          "type": "string",
          "description": "What the user wants to accomplish"
        },
        "domain": {
          "type": "string",
          "description": "Subject domain"
        },
        "human_goal": {
          "type": "string",
          "description": "Underlying human objective"
        },
        "requires_human_decision": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "governance": {
      "type": "object",
      "description": "Risk and policy controls",
      "properties": {
        "risk_tier": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "default": "medium"
        },
        "dry_run": {
          "type": "boolean",
          "default": true,
          "description": "If true, validate only without side effects"
        },
        "allow_execution": {
          "type": "boolean",
          "default": false
        },
        "policy_version": {
          "type": "string",
          "default": "arifOS.constitution.v1"
        },
        "authority": {
          "type": "string",
          "enum": ["advisory_only", "conditional", "full"],
          "default": "advisory_only"
        }
      }
    },
    "context": {
      "type": "object",
      "description": "Operational context and history",
      "properties": {
        "stage_history": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Stages already traversed"
        },
        "memory_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to relevant memory"
        },
        "vault_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to sealed records"
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Hard constraints to respect"
        }
      }
    },
    "payload": {
      "type": "object",
      "description": "Tool-specific parameters"
    },
    "telemetry": {
      "type": "object",
      "description": "Observability metadata",
      "properties": {
        "request_id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "caller_context": {
          "type": "object",
          "properties": {
            "channel": { "type": "string" },
            "surface": { "type": "string" }
          }
        },
        "debug": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
