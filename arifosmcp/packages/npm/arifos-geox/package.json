{
  "name": "@arifos/geox",
  "version": "2026.05.25",
  "description": "arifOS GEOX Domain Package — TypeScript surface for geoscience intelligence tools. Depends on @arifos/mcp for transport and governance envelopes.",
  "keywords": [
    "geox",
    "arifos",
    "geoscience",
    "mcp",
    "petrophysics",
    "subsurface"
  ],
  "homepage": "https://geox.arif-fazil.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ariffazil/arifos.git",
    "directory": "arifosmcp/packages/npm/arifos-geox"
  },
  "bugs": {
    "url": "https://github.com/ariffazil/arifos/issues"
  },
  "license": "AGPL-3.0-only",
  "author": "Muhammad Arif bin Fazil <arifos@arif-fazil.com>",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.mjs",
      "require": "./dist/register.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/types.ts src/client.ts src/register.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@arifos/mcp": ">=0.5.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@arifos/mcp": "file:../arifos-mcp",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "_updated": "2026.05.25"
}
