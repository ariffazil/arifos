{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifOS.context_packet.heart",
  "context_packet_version": "1.0.0",
  "tool_id": "arifos.heart",
  "stage": "666_HEART",
  "stage_order": 5,
  "desc": "Safety critique",
  "trinity": "Ω",
  "trinity_name": "Stability",
  "uri": "/arifOS/runtime/asi_heart",
  "backing_tool": "asi_heart",
  "role": "safety",
  "role_description": "Safety critique and stress testing",
  "modes": ["critique", "simulate"],
  "default_mode": "critique",
  "purpose": "Stress test proposals for safety, dignity, misuse potential, and contextual instability. The conscience of arifOS - speaks for what could go wrong.",
  "when_to_use": [
    "Before any consequential action",
    "After arifos.mind produces candidate actions",
    "Before arifos.judge for safety-critical decisions",
    "Need to check for dignity impacts",
    "Checking for misuse potential",
    "Evaluating edge cases and failure modes"
  ],
  "when_not_to_use": [
    "Do not use for pure information retrieval",
    "Do not use when no action is proposed",
    "Do not use as final authority - it advises judge",
    "Do not skip for high-consequence actions - mandatory"
  ],
  "not_job": [
    "Not a decision maker - advises only",
    "Not a reasoning engine - critiques reasoning",
    "Not a cost estimator - that's arifos.ops",
    "Not an execution validator - that's forge"
  ],
  "inputs": {
    "mode": {
      "type": "string",
      "enum": ["critique", "simulate"],
      "description": "critique: analyze proposal, simulate: model outcomes"
    },
    "required_payload": {
      "candidate_action": "object - What is being proposed",
      "context": "string - Situation and constraints"
    },
    "optional_payload": {
      "stress_dimensions": "string[] - What to check for",
      "simulation_depth": "string - quick|standard|deep"
    }
  },
  "outputs": {
    "primary": "safety_assessment",
    "shape": {
      "safety_score": "number - 0.0-1.0",
      "concern_flags": "object[] - Issues found",
      "stress_test_results": "object[] - Edge cases",
      "dignity_impacts": "string[] - Human-centered concerns",
      "misuse_vectors": "string[] - Potential abuses",
      "mitigation_suggestions": "string[] - How to improve",
      "recommendation": "string - proceed|caution|halt"
    }
  },
  "state_behavior": {
    "reads_state": true,
    "writes_state": false,
    "external_side_effects": false,
    "pure_analysis": true
  },
  "authority_model": {
    "advisory_only": true,
    "safety_authority": true,
    "can_recommend_halt": true,
    "cannot_override_judge": false
  },
  "context_contract": {
    "consumes": [
      "candidate actions",
      "context constraints",
      "governance rules",
      "historical incidents"
    ],
    "emits": [
      "safety assessment",
      "concern flags",
      "stress test results",
      "mitigation suggestions"
    ]
  },
  "routing_hints": {
    "upstream": ["arifos.mind"],
    "downstream": ["arifos.judge"],
    "mandatory_before": ["FORGE_010"],
    "typical_flow": ["333_MIND → 666_HEART → 888_JUDGE"]
  },
  "governance_requirements": {
    "risk_tier": "high",
    "dry_run_allowed": true,
    "mandatory_for_consequential": true
  },
  "chatgpt_guidance": {
    "plain_english": "Use this as a safety check before acting. It asks 'what could go wrong?' and is REQUIRED before any execution.",
    "key_phrases": ["is this safe", "what could go wrong", "stress test", "safety check", "dignity impact"],
    "ask_before_use_if": [
      "the action affects users or systems",
      "you're unsure about edge cases"
    ],
    "do_not_assume": [
      "heart is being overly cautious - its concerns are valid",
      "you can skip heart for 'simple' actions - use judgment",
      "heart's assessment is final - judge reviews it"
    ],
    "ideal_prompt_shape": {
      "mode": "critique",
      "candidate_action": {
        "type": "code_modification",
        "target": "authentication.py",
        "change": "Add OAuth flow"
      },
      "context": "Production system with 10k users"
    }
  }
}
