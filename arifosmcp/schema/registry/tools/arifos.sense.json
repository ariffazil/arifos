{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifOS.context_packet.sense",
  "context_packet_version": "1.0.0",
  "tool_id": "arifos.sense",
  "stage": "111_SENSE",
  "stage_order": 1,
  "desc": "Reality grounding",
  "trinity": "Δ",
  "trinity_name": "Discernment",
  "uri": "/arifOS/runtime/physics_reality",
  "backing_tool": "physics_reality",
  "role": "grounding",
  "role_description": "Evidence collection and reality verification",
  "modes": ["search", "ingest", "compass", "atlas", "time"],
  "default_mode": "compass",
  "purpose": "Ground tasks in verifiable reality: time, source evidence, environmental facts, and current context. Prevents hallucination by anchoring reasoning to observable truth.",
  "when_to_use": [
    "Need to verify current state of external systems",
    "Gathering evidence before making decisions",
    "Checking time-sensitive information",
    "Mapping available resources or capabilities",
    "Orienting within a problem space",
    "Need source citations for claims"
  ],
  "when_not_to_use": [
    "Do not use for synthesis - that's arifos.mind",
    "Do not use for safety evaluation - that's arifos.heart",
    "Do not use for final decisions - that's arifos.judge",
    "Do not use to retrieve historical memory - that's arifos.memory"
  ],
  "not_job": [
    "Not a reasoning or synthesis engine",
    "Not a safety evaluator",
    "Not a decision maker",
    "Not a memory store"
  ],
  "inputs": {
    "mode": {
      "type": "string",
      "enum": ["search", "ingest", "compass", "atlas", "time"],
      "description": "Sensing mode: search (find), ingest (load), compass (orient), atlas (map), time (temporal)"
    },
    "required_payload": {
      "query": "string - What reality to sense",
      "evidence_type": "string - Type of evidence needed"
    },
    "optional_payload": {
      "sources": "string[] - Preferred evidence sources",
      "freshness_requirement": "string - How recent data must be",
      "confidence_threshold": "number - Minimum evidence quality"
    }
  },
  "outputs": {
    "primary": "grounded_context",
    "shape": {
      "evidence_bundle": "object[] - Collected evidence with provenance",
      "grounded_facts": "string[] - Verified statements",
      "uncertainty_markers": "object[] - Known gaps or ambiguities",
      "timestamp": "timestamp - When sensing occurred",
      "sources": "string[] - Evidence sources"
    }
  },
  "state_behavior": {
    "reads_state": true,
    "writes_state": false,
    "external_side_effects": false,
    "query_external_systems": true
  },
  "authority_model": {
    "advisory_only": true,
    "provides_evidence": true,
    "requires_human_confirmation": false,
    "evidence_quality": "observable but not absolute truth"
  },
  "context_contract": {
    "consumes": [
      "session context",
      "query specification",
      "evidence requirements"
    ],
    "emits": [
      "grounded facts",
      "evidence bundle",
      "uncertainty markers",
      "source provenance"
    ]
  },
  "routing_hints": {
    "upstream": ["arifos.init", "arifos.route"],
    "downstream": ["arifos.mind", "arifos.memory"],
    "typical_flow": ["111_SENSE → 333_MIND (reason on evidence)", "111_SENSE → 555_MEMORY (store evidence)"]
  },
  "governance_requirements": {
    "risk_tier": "low",
    "dry_run_allowed": true,
    "read_only": true
  },
  "chatgpt_guidance": {
    "plain_english": "Use this to gather facts and evidence before thinking or deciding. It checks reality so you don't hallucinate.",
    "key_phrases": ["what is the current state", "search for", "find evidence", "check time", "map resources"],
    "ask_before_use_if": [
      "you're about to reason without checking facts",
      "the task involves external systems you haven't verified"
    ],
    "do_not_assume": [
      "sensed data is complete",
      "sensed data is perfectly accurate",
      "sensing is free - it has cost and latency"
    ],
    "ideal_prompt_shape": {
      "mode": "compass",
      "query": "What are the current security advisories for Python 3.12?",
      "evidence_type": "security_bulletin"
    }
  }
}
