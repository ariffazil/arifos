{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifOS.context_packet.memory",
  "context_packet_version": "1.0.0",
  "tool_id": "arifos.memory",
  "stage": "555_MEMORY",
  "stage_order": 4,
  "desc": "Governed memory",
  "trinity": "Ω",
  "trinity_name": "Stability",
  "uri": "/arifOS/runtime/engineering_memory",
  "backing_tool": "engineering_memory",
  "role": "memory",
  "role_description": "Governed episodic and semantic memory",
  "modes": ["vector_query", "vector_store", "engineer", "query"],
  "default_mode": "vector_query",
  "purpose": "Store and retrieve governed episodic, semantic, and engineering memory with provenance, scope control, and confidence scoring. Memory that persists across sessions.",
  "when_to_use": [
    "Need long-term project context",
    "Retrieving reusable architecture knowledge",
    "Scoped retrieval across sessions",
    "Storing important findings for future use",
    "Engineering memory operations",
    "Need memory with provenance tracking"
  ],
  "when_not_to_use": [
    "Do not use as final truth source - verify retrieved memory",
    "Do not treat as immutable ledger - that's arifos.vault",
    "Do not store speculative or unsafe claims",
    "Do not use for session state - that's arifos.init",
    "Do not store large raw data - memory is for context, not storage"
  ],
  "not_job": [
    "Not a database for raw data",
    "Not an immutable ledger",
    "Not a source of absolute truth",
    "Not session management",
    "Not a file system"
  ],
  "inputs": {
    "mode": {
      "type": "string",
      "enum": ["vector_query", "vector_store", "engineer", "query"],
      "description": "vector_query: semantic search, vector_store: save, engineer: structured ops, query: direct lookup"
    },
    "required_payload": {
      "query": "string - What to retrieve or store",
      "session_id": "string - Session context"
    },
    "optional_payload": {
      "domain_scope": "string - Limit search scope",
      "confidence_threshold": "number - Minimum match quality",
      "metadata": "object - Provenance and tags"
    }
  },
  "outputs": {
    "primary": "retrieved_memory",
    "shape": {
      "results": "object[] - Memory entries with scores",
      "confidence_scores": "number[] - Match quality per result",
      "sources": "string[] - Provenance",
      "write_candidates": "object[] - Suggested stores (if query mode)"
    }
  },
  "state_behavior": {
    "reads_state": true,
    "writes_state": true,
    "mutable": true,
    "external_side_effects": false
  },
  "authority_model": {
    "advisory_only": true,
    "retrieval_authority": true,
    "storage_requires_confirmation": true,
    "human_confirmation_required_for_policy_writes": true
  },
  "context_contract": {
    "consumes": [
      "query intent",
      "session state",
      "domain scope"
    ],
    "emits": [
      "retrieved memory",
      "write candidates",
      "confidence signals",
      "provenance metadata"
    ]
  },
  "routing_hints": {
    "upstream": ["arifos.init", "arifos.sense", "arifos.mind"],
    "downstream": ["arifos.mind", "arifos.judge"],
    "typical_flow": ["333_MIND → 555_MEMORY (store)", "555_MEMORY → 333_MIND (retrieve reason)"]
  },
  "governance_requirements": {
    "risk_tier": "medium",
    "dry_run_allowed": true,
    "writes_are_provisional": true
  },
  "chatgpt_guidance": {
    "plain_english": "Use for governed recall and storage of project knowledge. It's your long-term memory, but verify what you retrieve - it's not a vault seal.",
    "key_phrases": ["remember", "recall", "store", "what did we decide", "project context"],
    "ask_before_use_if": [
      "you're storing something with policy implications",
      "retrieved memory contradicts other sources"
    ],
    "do_not_assume": [
      "retrieved memory is current",
      "stored memory is immediately available",
      "memory is a substitute for vault sealing"
    ],
    "ideal_prompt_shape": {
      "mode": "vector_query",
      "query": "What authentication patterns did we decide on for the API?",
      "domain_scope": "project_arifos",
      "session_id": "sess_xxx"
    }
  }
}
