# arifOS MCP Environment Configuration
# ===================================
# Copy to .env and customize as needed

# Supabase Configuration (Multi-Agent Shared Memory)
SUPABASE_PASSWORD=fVw7szhEx9LDbs0I
SUPABASE_PROJECT=utbmmjmbolmuahwixjqc
SUPABASE_HOST=db.utbmmjmbolmuahwixjqc.supabase.co
SUPABASE_PORT=5432
SUPABASE_DB=postgres

# Note: Use SUPABASE_PASSWORD (PostgreSQL password), not the sbp_ token
# Connection: postgresql://postgres:{SUPABASE_PASSWORD}@{SUPABASE_HOST}:{SUPABASE_PORT}/{SUPABASE_DB}

# Memory Engine v1 Configuration
MEMORY_DB_URL=postgresql://postgres:{SUPABASE_PASSWORD}@{SUPABASE_HOST}:{SUPABASE_PORT}/{SUPABASE_DB}
MEMORY_QDRANT_URL=http://qdrant:6333
MEMORY_QDRANT_COLLECTION=arifos_memory
MEMORY_EMBED_MODEL=bge-m3:latest
MEMORY_EMBED_DIM=1024
MEMORY_WRITE_THRESHOLD_WORKING=0.40
MEMORY_WRITE_THRESHOLD_EPISODIC=0.55
MEMORY_WRITE_THRESHOLD_SEMANTIC=0.65
MEMORY_WRITE_THRESHOLD_PROCEDURAL=0.65
MEMORY_WRITE_THRESHOLD_POLICY=0.80
MEMORY_POLICY_REVIEW_REQUIRED_FOR=policy,sensitive

# Legacy Local PostgreSQL (DEPRECATED for vault/memory, still used for Qdrant sync)
# DATABASE_URL=postgresql://arifos_admin:arifos_secret@postgres:5432/arifos_vault

