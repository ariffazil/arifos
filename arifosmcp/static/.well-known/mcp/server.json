{
  "$schema": "https://static.modelcontextprotocol.io/schemas/mcp-server-card/v1.json",
  "version": "1.0",
  "protocolVersion": "2025-11-25",
  "serverInfo": {
    "name": "arifos-mcp",
    "title": "arifOS Constitutional MCP Server",
    "version": "2026.06.23-seven-tool-facade"
  },
  "description": "Governed MCP server — 7 public tools. One intent = one tool. Expose cognition, hide plumbing. Human approval gates on irreversible actions, VAULT999 immutable ledger, 888 Judge arbitration, hard seal gate on execution.",
  "transport": {
    "type": "streamable-http",
    "endpoint": "https://mcp.arif-fazil.com/mcp"
  },
  "authentication": {
    "required": true,
    "schemes": ["bearer"],
    "headerName": "Authorization",
    "envVar": "ARIFOS_API_KEY"
  },
  "capabilities": {
    "tools": { "listChanged": true },
    "resources": { "subscribe": true, "listChanged": true },
    "prompts": { "listChanged": true }
  },
  "governance": {
    "humanApprovalRequiredForIrreversibleActions": true,
    "selfApprovalForbidden": true,
    "auditRequired": true,
    "defaultMutationMode": "dry_run",
    "leaseRequiredForMutation": true,
    "constitutionalFloors": ["L01_Amanah","L02_Truth","L03_Witness","L04_Clarity","L05_Peace","L06_Empathy","L07_Humility","L08_Genius","L09_AntiHantu","L10_Ontology","L11_Audit","L12_Injection","L13_Sovereign"],
    "verdictTaxonomy": ["SEAL","HOLD","VOID","SABAR","PROCEED","888_HOLD"],
    "irreversibleGate": "arif_act requires seal_verdict_id from arif_seal"
  },
  "links": {
    "homepage": "https://arif-fazil.com",
    "status": "https://mcp.arif-fazil.com/health",
    "constitution": "https://arif-fazil.com/000"
  },
  "tools": {
    "count": 7,
    "frozen": "2026-06-23",
    "naming": "arif_noun_verb — one intent = one public tool",
    "contract": [
      {
        "name": "arif_init",
        "stage": "000",
        "description": "Start or resume a governed session. CALL THIS FIRST.",
        "actionClass": "PREPARE",
        "irreversible": false,
        "requiresSession": false
      },
      {
        "name": "arif_observe",
        "stage": "111",
        "description": "Search the web, check system vitals, gather real-world data.",
        "actionClass": "OBSERVE",
        "irreversible": false,
        "requiresSession": true
      },
      {
        "name": "arif_think",
        "stage": "333",
        "description": "Multi-step reasoning, planning, reflection with confidence labeling.",
        "actionClass": "ANALYZE",
        "irreversible": false,
        "requiresSession": true
      },
      {
        "name": "arif_route",
        "stage": "444",
        "description": "Routes intent to the correct federation organ.",
        "actionClass": "ANALYZE",
        "irreversible": false,
        "requiresSession": true
      },
      {
        "name": "arif_judge",
        "stage": "888",
        "description": "Render final constitutional verdict. Returns SEAL/HOLD/VOID.",
        "actionClass": "DRAFT",
        "irreversible": false,
        "requiresSession": true
      },
      {
        "name": "arif_act",
        "stage": "900",
        "description": "Execute approved action. REQUIRES valid seal_verdict_id from arif_seal. No seal = 888_HOLD.",
        "actionClass": "MUTATE",
        "irreversible": true,
        "requiresSession": true,
        "requiresSeal": true
      },
      {
        "name": "arif_seal",
        "stage": "999",
        "description": "Seal verdict to immutable audit ledger. Permanent record.",
        "actionClass": "IRREVERSIBLE",
        "irreversible": true,
        "requiresSession": true
      }
    ],
    "requiresHumanAck": ["arif_seal", "arif_act"],
    "requiresSeal": ["arif_act"]
  },
  "resources": {
    "count": 5,
    "uris": [
      "arifos://doctrine",
      "arifos://vitals",
      "arifos://schema",
      "arifos://session/{session_id}",
      "arifos://forge"
    ]
  },
  "prompts": {
    "count": 8,
    "names": ["system","judge","init","rsi","ortho","epistemic","governance","entropy"]
  }
}
