# arifOS Continue CLI Config — TEMPLATE
# Copy to ~/.continue/config.yaml and fill in your MINIMAX_API_KEY
# DO NOT commit the real config — it contains secrets.

name: arifOS-Federation
version: 1.0.0
schema: v1

models:
  - name: MiniMax M3
    provider: anthropic
    apiKey: <YOUR_MINIMAX_API_KEY_HERE>   # <-- fill in
    apiBase: https://api.minimax.io/anthropic/v1   # NB: must include /v1
    model: MiniMax-M3
    roles:
      - chat
      - edit
      - apply
      - autocomplete
    default: true

mcpServers:
  - name: A-FORGE
    command: node
    args:
      - /root/A-FORGE/dist/src/mcp/cli.js
      - serve
      - --transport
      - stdio
    cwd: /root/A-FORGE
    env:
      NODE_ENV: development
      AF_FORGE_PORT: "7071"

rules:
  - /root/AGENTS.md
  - /root/CONTEXT.md
  - /root/RUNBOOK.md
  - <this-repo>/continue-arifos/rules/constitutional.md
