# arifOS — Force LF line endings on all text files
# DITEMPA BUKAN DIBERI — Forged, Not Given

* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Python
*.py text eol=lf

# Makefiles
Makefile text eol=lf
makefile text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Node
*.js text eol=lf
*.ts text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# PowerShell (keep as-is, Windows-native)
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Windows-specific (keep CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
