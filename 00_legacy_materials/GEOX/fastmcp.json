{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "control_plane/fastmcp/server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv"
  },
  "deployment": {
    "transport": "stdio",
    "env": {
      "GEOX_VERSION": "0.5.0",
      "GEOX_SEAL": "DITEMPA BUKAN DIBERI"
    }
  },
  "tools": {
    "visibility": {
      "model": ["geox_*"],
      "app": ["geox_*"]
    }
  },
  "meta": {
    "constitutional_floors": ["F1", "F2", "F4", "F7", "F9", "F11", "F13"],
    "category": "science",
    "subcategory": "geology",
    "license": "AGPL-3.0"
  }
}
