# arifOS Manifestation Policy (v2026.4.16)
# Ditempa Bukan Diberi.

# Include core logic
recursive-include arifosmcp *.py *.json *.html *.css
include pyproject.toml
include README.md
include LICENSE
include program.md

# Prune Metabolic Shadows
recursive-exclude arifosmcp/__pycache__ *
recursive-exclude tests *
recursive-exclude docs *
recursive-exclude .archive *
recursive-exclude VAULT999/STAGING *
recursive-exclude arifosmcp/.venv *

# Prune Tool Build Bloat
exclude .env
exclude .env.example
exclude Makefile
exclude uv.lock
exclude MANIFEST.in
exclude *.txt
exclude *.json
