# arifOS — FHS-Aligned Gitignore
# Constitutional governance: runtime state must never be in git.
# DITEMPA BUKAN DIBERI — Forged, Not Given

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Import Linter
.importlinter_cache/

# F8 Hygiene - Live secrets (888_HOLD confirmed)
SECRETS.yml
secrets/

# Ops tooling — not canonical source
OPERATIONS/

# ── FHS Runtime Paths (never in git) ───────────────────────────────
# These paths are runtime-only. Git tracks source, not state.
# Git tracks source. Container enforces FHS. Runtime state is outside git.
/var/lib/arifOS/
/var/lib/arifOS/**
/run/arifOS/
/run/arifOS/**
/tmp/arifOS/
/tmp/arifOS/**

# ── Runtime Artifacts (never in git) ───────────────────────────────
benchmark_report.json
SEALED_EVENTS.jsonl
*.jsonl

# SQLite databases
*.db

# arifOS secret files
*.secret
secrets/*.secret

# Memory artifacts
memory/
*.bin

# Logs and telemetry
logs/
telemetry/
!deploy/telemetry/
data/
*.log

# Docker
.dockerignore

# IDEs
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.log*
/arifosmcp/

# ── Shadowing prevention ─────────────────────────────────────────────
# mcp/ shadows the PyPI mcp package in sys.path. Never track it.
mcp/
# mcp_server/ is forge-seal output and also shadows PyPI mcp package.
mcp_server/
.env
.env.*
