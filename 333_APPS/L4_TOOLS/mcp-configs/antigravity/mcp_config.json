{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "arifOS AAA MCP v55.5-HARDENED — Antigravity Config",
  "mcpServers": {
    "aaa-mcp": {
      "command": "C:\\Users\\User\\arifOS\\venv\\Scripts\\python.exe",
      "args": ["-m", "aaa_mcp", "stdio"],
      "cwd": "C:/Users/User/arifOS",
      "env": {
        "PYTHONPATH": "C:/Users/User/arifOS",
        "ARIFOS_MODE": "PROD",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1"
      },
      "disabled": false,
      "alwaysAllow": [
        "init_gate",
        "forge_pipeline",
        "agi_sense",
        "agi_think",
        "agi_reason",
        "asi_empathize",
        "asi_align",
        "apex_verdict",
        "reality_search",
        "vault_seal",
        "vault_query",
        "tool_router",
        "truth_audit"
      ]
    }
  }
}
