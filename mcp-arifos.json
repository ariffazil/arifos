{
  "$schema": "https://modelcontextprotocol.io/specification",
  "server_info": {
    "name": "arifOS MCP",
    "version": "2026.05.04-MANIFEST-FIX",
    "description": "Constitutional governance kernel MCP. Enforces F1-F13 floors, VAULT999 audit, 888_HOLD human veto. 13 canonical tools."
  },
  "source": {
    "path": "arifosmcp/server.py",
    "entrypoint": "mcp",
    "repo": "https://github.com/ariffazil/arifOS",
    "repo_path": "/opt/arifos/src/arifOS"
  },
  "environment": {
    "runtime": "python",
    "python_version": ">=3.12",
    "package_manager": "uv",
    "dependencies": [
      "fastmcp>=3.0,<4.0",
      "uvicorn",
      "fastapi>=0.100.0",
      "pydantic>=2.0"
    ]
  },
  "deployment": {
    "transport": "streamable-http",
    "endpoint": "https://mcp.arif-fazil.com/mcp",
    "port": 8088,
    "container": "arifosmcp",
    "docker_image": "ariffazil/arifosmcp:latest"
  },
  "capabilities": {
    "tools": {
      "count": 13,
      "list_endpoint": "/tools",
      "call_endpoint": "/tools/{tool_name}"
    },
    "resources": {
      "enabled": true,
      "list_endpoint": "/resources"
    },
    "prompts": {
      "enabled": true,
      "list_endpoint": "/prompts"
    },
    "apps": {
      "available": true,
      "ui_extension": "prefab-ui",
      "entries": [
        {
          "id": "arifos_command_center",
          "name": "arifOS Command Center",
          "description": "Interactive MCP cockpit for governed session, ops, judge, forge, gateway, and vault review.",
          "entry_tool": "arifos_command_center",
          "status": "v0.1_evaluation_ready",
          "risk_tier": "medium",
          "default_mode": "dry_run_only",
          "human_authority_required": true
        }
      ]
    }
  },
  "tools": [
    {"name": "arif_session_init", "stage": "000_INIT", "lane": "AGI", "floors": ["L01", "L11", "L12"], "risk_tier": "critical"},
    {"name": "arif_vault_seal", "stage": "999_VAULT", "lane": "APEX", "floors": ["L01", "L11", "L13"], "risk_tier": "critical"},
    {"name": "arif_sense_observe", "stage": "111_SENSE", "lane": "AGI", "floors": ["L02"], "risk_tier": "low"},
    {"name": "arif_heart_critique", "stage": "666_HEART", "lane": "ASI", "floors": ["L05", "L06"], "risk_tier": "medium"},
    {"name": "arif_forge_execute", "stage": "010_FORGE", "lane": "AGI", "floors": ["L01", "L11", "L13"], "risk_tier": "critical"},
    {"name": "arif_mind_reason", "stage": "333_MIND", "lane": "AGI", "floors": ["L02", "L07", "L08"], "risk_tier": "medium"},
    {"name": "arif_judge_deliberate", "stage": "888_JUDGE", "lane": "ASI", "floors": ["L11", "L13"], "risk_tier": "critical"},
    {"name": "arif_kernel_route", "stage": "444_KERNEL", "lane": "AGI", "floors": ["L01", "L04"], "risk_tier": "medium"},
    {"name": "arif_ops_measure", "stage": "777_OPS", "lane": "AGI", "floors": ["L04"], "risk_tier": "low"},
    {"name": "arif_memory_recall", "stage": "555_MEMORY", "lane": "AGI", "floors": ["L01", "L08"], "risk_tier": "low"},
    {"name": "arif_evidence_fetch", "stage": "222_FETCH", "lane": "AGI", "floors": ["L02", "L03"], "risk_tier": "low"},
    {"name": "arif_reply_compose", "stage": "444r_REPLY", "lane": "AGI", "floors": ["L04", "L06", "L09"], "risk_tier": "low"},
    {"name": "arif_gateway_connect", "stage": "666g_GATEWAY", "lane": "ASI", "floors": ["L01", "L03"], "risk_tier": "medium"}
  ],
  "constitutional_floors": {
    "count": 13,
    "hard": ["F1", "F2", "F6", "F9", "L10", "L11", "L13"],
    "soft": ["F3", "F4", "F5", "F7", "F8", "L12"]
  },
  "endpoints": {
    "mcp": "https://mcp.arif-fazil.com/mcp",
    "health": "https://mcp.arif-fazil.com/health",
    "tools": "https://mcp.arif-fazil.com/tools",
    "metrics": "https://mcp.arif-fazil.com/metrics/json",
    "openapi": "https://mcp.arif-fazil.com/openapi.json",
    "server_manifest": "https://mcp.arif-fazil.com/.well-known/mcp/server.json"
  },
  "platform_agnostic": true,
  "model_agnostic": true,
  "protocol": {
    "standard": "MCP",
    "transports": ["streamable_http"],
    "endpoint": "https://mcp.arif-fazil.com/mcp"
  },
  "apps": {
    "supported": true,
    "extension": "io.modelcontextprotocol/ui",
    "fallback_required": true,
    "fallback_modes": ["text", "json"],
    "primary_app": {
      "id": "arifos_command_center",
      "name": "arifOS Command Center MCP",
      "description": "Interactive governance cockpit for arifOS MCP.",
      "ui_resource": "ui://arifos/command-center.html"
    }
  },
  "governance": {
    "authority": "Human 888 Judge",
    "self_approval_allowed": false,
    "audit_required": true,
    "default_mode": "dry_run_only",
    "irreversible_actions_require_ack": true
  }
}
