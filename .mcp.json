{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "arifOS Kimi CLI MCP Configuration v55.5-EIGEN - 9 Canonical Tools + 6 External MCPs",
  "mcpServers": {
    "_comment_aaa": "=== CONSTITUTIONAL CORE (9 Canonical Tools) ===",
    "aaa-mcp": {
      "command": "python",
      "args": ["-m", "aaa_mcp", "stdio"],
      "cwd": "C:/Users/User/arifOS",
      "env": {
        "PYTHONPATH": "C:/Users/User/arifOS",
        "ARIFOS_CONSTITUTIONAL_MODE": "AAA",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1",
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "BROWSERBASE_API_KEY": "${BROWSERBASE_API_KEY}"
      },
      "disabled": false,
      "alwaysAllow": [
        "init_gate",
        "agi_sense",
        "agi_think",
        "agi_reason",
        "asi_empathize",
        "asi_align",
        "apex_verdict",
        "reality_search",
        "vault_seal"
      ]
    },

    "_comment_filesystem": "=== F1 AMANAH - Filesystem Operations (Reversible) ===",
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@latest", "C:/Users/User/arifOS"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "read_file",
        "read_multiple_files",
        "write_file",
        "edit_file",
        "list_directory",
        "list_directory_with_sizes",
        "directory_tree",
        "search_files",
        "get_file_info",
        "move_file",
        "create_directory"
      ]
    },

    "_comment_git": "=== F2 TRUTH - Git Operations (Version Control as Evidence) ===",
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git"],
      "cwd": "C:/Users/User/arifOS",
      "env": {
        "GIT_CONFIG_GLOBAL": ""
      },
      "disabled": false,
      "alwaysAllow": [
        "git_status",
        "git_diff",
        "git_diff_staged",
        "git_log",
        "git_show",
        "git_branch",
        "git_create_branch",
        "git_checkout",
        "git_add",
        "git_reset",
        "git_commit"
      ]
    },

    "_comment_memory": "=== F8 WISDOM - Knowledge Graph Memory (Pattern Storage) ===",
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@latest"],
      "env": {
        "MEMORY_FILE_PATH": "C:/Users/User/arifOS/.kimi/memory.json"
      },
      "disabled": false,
      "alwaysAllow": [
        "read_graph",
        "search_nodes",
        "open_nodes",
        "create_entities",
        "create_relations",
        "add_observations",
        "delete_entities",
        "delete_observations",
        "delete_relations"
      ]
    },

    "_comment_sequential": "=== F8 WISDOM - Sequential Thinking (Multi-step Reasoning) ===",
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@latest"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "sequentialthinking"
      ]
    },

    "_comment_fetch": "=== F2 TRUTH AUXILIARY - Fetch (Web Content Retrieval) ===",
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch@latest"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "fetch"
      ]
    },

    "_comment_time": "=== F6 CLARITY - Time (Temporal Precision) ===",
    "time": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time@latest"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "get_current_time",
        "convert_time"
      ]
    }
  }
}
