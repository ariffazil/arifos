{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ariffazil/arifos-mcp",
  "version": "2026.04.21-UNIFIED",
  "description": "arifOS AAA MCP runtime with streamable HTTP at /mcp, SSE compatibility, 13 public tools, and the arifOS dashboard app resources.",
  "vendor": {
    "name": "arifOS",
    "url": "https://arifos.arif-fazil.com"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "url": "https://github.com/ariffazil/arifOS",
    "source": "github"
  },
  "protocolVersion": "2025-11-25",
  "supportedProtocolVersions": ["2025-11-25", "2025-03-26", "2025-06-18"],
  "authentication": {
    "type": "none",
    "description": "No authentication required. actor_id is used for logging only."
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "arifos",
      "version": "2026.04.16",
      "transport": {
        "type": "stdio",
        "command": "python stdio_server.py"
      }
    },
    {
      "registryType": "oci",
      "identifier": "docker.io/ariffazil/arifosmcp:latest",
      "transport": {
        "type": "streamable-http",
        "url": "https://arifosmcp.arif-fazil.com/mcp"
      }
    }
  ],
  "remotes": [
    {
      "type": "sse",
      "url": "https://arifosmcp.arif-fazil.com/sse"
    },
    {
      "type": "streamable-http",
      "url": "https://arifosmcp.arif-fazil.com/mcp"
    }
  ],
  "resources": [
    {
      "uri": "arifos://aaa/schemas"
    },
    {
      "uri": "arifos://aaa/full-context-pack"
    },
    {
      "uri": "arifos://aaa/mcp-transport-profile"
    },
    {
      "uri": "arifos://aaa/tool-operating-manual"
    },
    {
      "uri": "arifos://aaa/governance-gate-profile"
    },
    {
      "uri": "ui://geox-dashboard"
    }
  ],
  "prompts": [
    "arifos.prompt.run_111_think",
    "arifos.prompt.run_777_reason",
    "arifos.prompt.run_888_audit",
    "arifos.prompt.forge_verdict"
  ]
}
