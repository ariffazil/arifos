{
  "$schema": "https://arif-fazil.com/schemas/arifos-policy-v1.json",
  "name": "arifOS MCP Governance Policy",
  "version": "2026.04.26",
  "authority": "Muhammad Arif bin Fazil (888 Judge)",
  "status": "v0.1_evaluation_ready",
  "platform_agnostic": true,
  "model_agnostic": true,
  "governance": {
    "authority": "Human 888 Judge",
    "self_approval_allowed": false,
    "audit_required": true,
    "default_mode": "dry_run_only",
    "irreversible_actions_require_ack": true,
    "constitutional_floors": 13,
    "hard_floors": ["F1", "F2", "F6", "F9", "L10", "L11", "L13"],
    "soft_floors": ["F3", "F4", "F5", "F7", "F8", "L12"]
  },
  "mcp": {
    "endpoint": "https://mcp.arif-fazil.com/mcp",
    "transports": ["streamable_http"],
    "apps_extension": {
      "supported": true,
      "identifier": "io.modelcontextprotocol/ui",
      "fallback_required": true,
      "fallback_modes": ["text", "json"]
    }
  },
  "apps": {
    "supported": true,
    "extension": "io.modelcontextprotocol/ui",
    "fallback_required": true,
    "fallback_modes": ["text", "json"],
    "primary_app": {
      "id": "arifos_command_center",
      "name": "arifOS Command Center MCP",
      "description": "Interactive governance cockpit for arifOS MCP.",
      "entry_tool": "command_center",
      "ui_resource": "ui://arifos/command-center.html",
      "status": "v0.1_evaluation_ready",
      "modules": [
        "session",
        "ops",
        "judge",
        "forge_dry_run",
        "gateway_handshake",
        "vault_review"
      ]
    }
  },
  "safety": {
    "hosted_endpoint_grade": "evaluation_only",
    "self_host_recommended_for": [
      "sensitive_workloads",
      "sovereign_deployments",
      "production_authority"
    ],
    "prohibited_in_v01": [
      "real_forge_execution",
      "real_vault_permanent_write",
      "real_gateway_network_calls",
      "sampling",
      "generative_ui",
      "self_approval",
      "credential_handling"
    ]
  },
  "disclaimer": "This hosted endpoint is evaluation-grade only. Self-host arifOS for sensitive, sovereign, or production workloads."
}
