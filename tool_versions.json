  "epistemic_classes": {
    "INIT": "System initialization, identity binding",
    "OBSERVED": "Direct observation or data retrieval",
    "LOADED": "Data loaded into session context",
    "FETCHED": "External source fetched",
    "COMPUTED": "Deterministic calculation result",
    "SIMULATED": "Monte Carlo or probabilistic simulation",
    "REASONED": "LLM interpretive reasoning",
    "CRITIQUED": "Ethical/risk critique by LLM",
    "JUDGED": "Constitutional adjudication",
    "VERIFIED": "Cross-checked against constraints",
    "RENDERED": "Visualization output",
    "QC": "Quality control check",
    "DISCOVERY": "Tool/skill discovery query",
    "CHECKED": "Policy or floor check",
    "MANAGED": "Lifecycle management action",
    "AUDITED": "Compliance audit performed",
    "SCORED": "Scoring computation",
    "DECIDED": "Decision under uncertainty",
    "ALLOCATED": "Budget/resource allocation",
    "TRIAGED": "Crisis triage",
    "GOVERNED": "Civilizational governance",
    "COORDINATED": "Multi-party coordination",
    "SOLVED": "Game theory solution",
    "RECORDED": "Immutable record written",
    "SNAPSHOTTED": "Point-in-time state capture",
    "VINTAGED": "Dated to specific time period",
    "RECONCILED": "Cross-source reconciliation",
    "VALIDATED": "Schema/structure validation",
    "ROUTED": "Routing decision, no mutation",
    "EXECUTED": "System mutation performed",
    "SEALED": "Immutable ledger entry created"
