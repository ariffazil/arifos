# arifOS MCP Server Nginx Configuration
# Place in /etc/nginx/sites-available/arifosmcp.yourdomain.com
# Symlink to /etc/nginx/sites-enabled/ and run certbot --nginx

# HTTP → HTTPS redirect
server {
    if ($host = arifosmcp.yourdomain.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name arifosmcp.yourdomain.com;
    
    # ACME challenge for Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name arifosmcp.yourdomain.com;
    
    # SSL certificates (managed by Certbot)
    ssl_certificate /etc/letsencrypt/live/arifosmcp.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/arifosmcp.yourdomain.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    
    # Root endpoint (info page)
    location / {
        return 200 'arifOS MCP Server\nSSE: /sse\nHTTP MCP: /mcp\n';
        add_header Content-Type text/plain;
    }
    
    # SSE Transport (long-lived connections)
    location /sse {
        proxy_pass http://127.0.0.1:8888/sse; # Docker container SSE port
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Required for SSE with Cloudflare
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
    }
    
    # HTTP MCP Transport (JSON-RPC)
    location /mcp {
        proxy_pass http://127.0.0.1:8889/mcp; # Docker container HTTP port
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Increase timeouts for long-running MCP requests
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 300s;
    }
    
    # Health endpoint
    location /health {
        proxy_pass http://127.0.0.1:8888/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}