{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "A-ORCHESTRATOR",
  "agent": {
    "A-ARCHITECT": {
      "mode": "primary",
      "description": "Design-only architect under arifOS Floors.",
      "prompt": ".opencode/agents/A-ARCHITECT.md",
      "tools": {
        "search_web": true,
        "fetch_url": true,
        "execute_code": false,
        "bash": false,
        "edit": false
      }
    },
    "A-ENGINEER": {
      "mode": "primary",
      "description": "Implementation under 888_HOLD and Vault.",
      "prompt": ".opencode/agents/A-ENGINEER.md",
      "tools": {
        "search_web": true,
        "fetch_url": true,
        "execute_code": true,
        "bash": true,
        "edit": true,
        "mcp": true
      },
      "permission": {
        "bash": "ask",
        "edit": "ask"
      }
    },
    "A-AUDITOR": {
      "mode": "subagent",
      "prompt": ".opencode/agents/A-AUDITOR.md",
      "tools": {
        "search_web": true,
        "fetch_url": true,
        "execute_code": true,
        "bash": false,
        "edit": false
      }
    },
    "A-VALIDATOR": {
      "mode": "subagent",
      "prompt": ".opencode/agents/A-VALIDATOR.md",
      "tools": {
        "search_web": true,
        "fetch_url": true,
        "execute_code": true
      }
    },
    "A-ORCHESTRATOR": {
      "mode": "primary",
      "prompt": ".opencode/agents/A-ORCHESTRATOR.md",
      "tools": {
        "search_web": true,
        "fetch_url": true,
        "execute_code": true,
        "bash": false,
        "edit": false,
        "task": true,
        "mcp": true
      },
      "permission": {
        "task": {
          "A-*": "allow"
        }
      }
    }
  },
  "mcp": {
    "arifos-sovereign": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "arifosmcp.opencode_mcp",
        "sovereign"
      ],
      "enabled": true,
      "environment": {
        "ARIFOS_MODE": "strict"
      }
    },
    "arifos-kernel": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "arifosmcp.runtime",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "ARIFOS_MODE": "strict"
      }
    },
    "arifos-intelligence": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "arifosmcp.opencode_mcp",
        "intelligence"
      ],
      "enabled": false,
      "environment": {
        "ARIFOS_MODE": "strict"
      }
    },
    "arifos-well": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "arifosmcp.opencode_mcp",
        "well"
      ],
      "enabled": false,
      "environment": {
        "ARIFOS_MODE": "strict"
      }
    },
    "arifos-wealth": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "arifosmcp.opencode_mcp",
        "wealth"
      ],
      "enabled": false,
      "environment": {
        "ARIFOS_MODE": "strict"
      }
    },
    "arifos-geox": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "arifosmcp.opencode_mcp",
        "geox"
      ],
      "enabled": false,
      "environment": {
        "ARIFOS_MODE": "strict"
      }
    },
    "arifos-public": {
      "type": "http",
      "url": "https://mcp.arif-fazil.com/mcp",
      "enabled": false
    }
  }
}
