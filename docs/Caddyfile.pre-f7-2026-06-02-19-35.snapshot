# ═══════════════════════════════════════════════════════════════════════
# LEGACY REDIRECTS — old subdomains → main sites
# ═══════════════════════════════════════════════════════════════════════
mcp.arif-fazil.com {
	import tls_origin
	# Legacy alias — canonical surface is arifos.arif-fazil.com
	# Keep /mcp* paths working for existing MCP clients; redirect humans to Observatory
	handle /mcp* {
		reverse_proxy 127.0.0.1:8088
	}
	handle /sse* {
		reverse_proxy 127.0.0.1:8088
	}
	handle {
		redir https://arifos.arif-fazil.com{uri} 301
	}
}
# ═══════════════════════════════════════════════════════════════════════
# FORGE WEBHOOK — A-FORGE event receiver + arifOS governance gateway
# Route: forge.arif-fazil.com/webhook/forge → port 7071 (A-FORGE)
# ─────────────────────────────────────────────────────────────────────
forge.arif-fazil.com {
	import tls_origin
	handle /webhook/forge* {
		reverse_proxy 127.0.0.1:8443
	}
	handle /webhook/github* {
		reverse_proxy 127.0.0.1:8443
	}
	handle /health {
		reverse_proxy 127.0.0.1:7071
	}
	handle {
		respond "forge.arif-fazil.com — A-FORGE webhook gateway"
	}
}
# Aliases: a-forge.arif-fazil.com + aforge.arif-fazil.com → A-FORGE :7071
# (closes the 525 — both names previously had no Caddy vhost)
a-forge.arif-fazil.com, aforge.arif-fazil.com {
	import tls_origin
	handle /webhook/forge* {
		reverse_proxy 127.0.0.1:8443
	}
	handle /webhook/github* {
		reverse_proxy 127.0.0.1:8443
	}
	handle /health {
		reverse_proxy 127.0.0.1:7071
	}
	handle /api/federation-probe* {
		reverse_proxy 127.0.0.1:7071
	}
	handle {
		respond "a-forge.arif-fazil.com — A-FORGE alias (7071)"
	}
}
wiki.arif-fazil.com {
	import tls_origin
	import shared_assets
	encode zstd gzip
	root * /var/www/html/wiki
	handle {
		try_files {path} /index.html
		file_server
	}
}
# MAIN SITE 3 — Δ AAA COCKPIT
# ═══════════════════════════════════════════════════════════════════════
aaa.arif-fazil.com {
	import tls_origin
	import shared_assets
	encode zstd gzip
	root * /var/www/html/aaa

	@a2a_static path /a2a/agent-card.json /a2a/agent.json /a2a/agents.json /a2a/status.json /a2a/index.html
	handle @a2a_static {
		file_server
	}

	handle /a2a/* {
		reverse_proxy 127.0.0.1:3001
	}
	handle /api/* {
		reverse_proxy 127.0.0.1:3001
	}
	handle /health {
		reverse_proxy 127.0.0.1:3001
	}


	handle /ready {
		rewrite * /health
		reverse_proxy 127.0.0.1:3001
	}
	handle /.well-known/* {
		reverse_proxy 127.0.0.1:3001
	}

	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
