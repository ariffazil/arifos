# ═══════════════════════════════════════════════════════════════════════
# OPENCLAW WEBHOOK PROXY
# ═══════════════════════════════════════════════════════════════════════
claw.arif-fazil.com {
	import tls_origin
	# Proxy /telegram webhook calls to OpenClaw gateway
	handle /telegram* {
		reverse_proxy 127.0.0.1:18789
	}
	# Health check
	handle /health {
		reverse_proxy 127.0.0.1:18789
	}
	# Main gateway for OpenClaw web UI
	handle {
		reverse_proxy 127.0.0.1:18789
	}
}
# ═══════════════════════════════════════════════════════════════════════
# OPENCLAW GATEWAY
# Telegram webhook: /telegram-webhook → port 8787 (monitor-webhook process)
# UI + everything else → port 18789
# ═══════════════════════════════════════════════════════════════════════
openclaw.arif-fazil.com {
	import tls_origin
	encode zstd gzip
	handle /telegram-webhook {
		reverse_proxy 127.0.0.1:8787
	}
	handle /.well-known/agent-card.json {
		reverse_proxy 127.0.0.1:18795
	}
	handle {
		reverse_proxy 127.0.0.1:18789
	}
}
