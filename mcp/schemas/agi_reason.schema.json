{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/agi_reason.schema.json",
  "title": "AGI Reason Output (Stage 333)",
  "description": "Output contract for the AGI reasoning stage. Produces structured logical conclusions with counterarguments and failure conditions.",
  "type": "object",
  "required": ["session_id", "vote", "conclusion", "confidence", "floor_scores"],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "premises": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Logical premises supporting the conclusion"
    },
    "inferences": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Inference steps from premises to conclusion"
    },
    "conclusion": {
      "type": "string",
      "description": "The reasoned conclusion"
    },
    "counterarguments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known counterarguments to the conclusion"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Overall confidence (precision-weighted, F7 Humility bounded)"
    },
    "failure_conditions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Conditions that would invalidate the conclusion"
    },
    "vote": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "UNCERTAIN"],
      "description": "AGI engine verdict"
    },
    "entropy_delta": {
      "type": "number",
      "description": "Net entropy change (F4: must be <= 0)"
    },
    "omega_0": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Uncertainty parameter (F7: must be in [0.03, 0.05])"
    },
    "free_energy": {
      "type": "number",
      "description": "F = delta_S + omega_0 * pi^-1"
    },
    "floor_scores": {
      "type": "object",
      "description": "AGI floor scores (F2, F4, F7, F10)"
    },
    "reflection": {
      "type": "object",
      "properties": {
        "what_was_assumed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "what_is_irreversible": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "weakest_point": {
          "type": "string",
          "description": "The weakest point in the reasoning chain"
        },
        "regret_minimization": {
          "type": "string",
          "description": "What the worst-case regret scenario looks like"
        }
      },
      "description": "Meta-reflection on the reasoning quality (optional, populated when reflect=true)"
    }
  },
  "additionalProperties": true
}
