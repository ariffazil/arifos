    "RECORDED": {"meaning": "Immutable record written", "domain": "WEALTH"},
    "SNAPSHOTTED": {"meaning": "Point-in-time state capture", "domain": "ANY"},
    "RECONCILED": {"meaning": "Cross-source reconciliation", "domain": "WEALTH"},
    "VALIDATED": {"meaning": "Schema/structure validation", "domain": "ANY"},
    "ROUTED": {"meaning": "Routing decision, no mutation", "domain": "arifOS"},
    "EXECUTED": {"meaning": "System mutation performed", "domain": "arifOS"},
    "SEALED": {"meaning": "Immutable ledger entry created (arifOS ONLY)", "domain": "arifOS"},
