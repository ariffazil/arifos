    "QC": {"meaning": "Quality control check performed", "domain": "GEOX"},
    "FETCHED": {"meaning": "External source fetched", "domain": "ANY"},
    "COMPUTED": {"meaning": "Deterministic calculation result", "domain": "ANY"},
    "SIMULATED": {"meaning": "Monte Carlo or probabilistic simulation", "domain": "WEALTH"},
    "REASONED": {"meaning": "LLM interpretive reasoning", "domain": "arifOS"},
    "CRITIQUED": {"meaning": "Ethical/risk critique by LLM", "domain": "arifOS"},
    "JUDGED": {"meaning": "Constitutional adjudication (arifOS ONLY)", "domain": "arifOS"},
    "VERIFIED": {"meaning": "Cross-checked against constraints", "domain": "GEOX"},
    "RENDERED": {"meaning": "Visualization output", "domain": "GEOX"},
    "DISCOVERY": {"meaning": "Tool/skill discovery query", "domain": "ANY"},
    "CHECKED": {"meaning": "Policy or floor check", "domain": "ANY"},
    "MANAGED": {"meaning": "Lifecycle management action", "domain": "arifOS"},
    "AUDITED": {"meaning": "Compliance audit performed", "domain": "WEALTH"},
    "SCORED": {"meaning": "Scoring computation", "domain": "WEALTH"},
    "DECIDED": {"meaning": "Decision under uncertainty", "domain": "WEALTH"},
    "ALLOCATED": {"meaning": "Budget/resource allocation", "domain": "WEALTH"},
    "TRIAGED": {"meaning": "Crisis triage", "domain": "WEALTH"},
    "GOVERNED": {"meaning": "Civilizational governance", "domain": "WEALTH"},
    "COORDINATED": {"meaning": "Multi-party coordination", "domain": "WEALTH"},
