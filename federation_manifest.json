  "escalation_tiers": {
    "0": {"label": "AUTONOMOUS", "description": "No human confirmation required"},
    "1": {"label": "HUMAN_CONFIRM", "description": "Explicit human acknowledgment before irreversible step"},
    "2": {"label": "MULTI_AGENT", "description": "Requires quorum from multiple domain agents"},
    "3": {"label": "CONSTITUTIONAL_FREEZE", "description": "Full governance halt, sovereign must intervene"}
  },

  "vault_seal_contract": {
    "required_fields": [
      "seal_id",
      "actor_id",
      "jwt_sub",
      "tool_name",
      "tool_version",
      "claim_state",
      "escalation_tier",
      "input_hash",
      "output_hash",
      "timestamp_utc"
    ],
    "optional_fields": [
      "evidence_refs",
      "confidence",
      "session_id",
      "epoch_id",
      "domain",
      "failure_modes",
      "uncertainty_reason"
    ],
    "actor_id_policy": "MUST match jwt_sub — spoofed actor_id is a F11 violation",
    "tool_version_policy": "MUST match entry in tool_versions.json — unknown versions rejected after enforce mode",
    "claim_state_policy": "MUST be in claim_tag_registry",
    "irreversible_writes_require": "T3 escalation_tier + human_signature + vault_entry_id"
  },

  "jwt_enforcement_policy": {
    "observe_mode": "Log violations but do not block. Collect telemetry for 24h minimum.",
    "enforce_mode": "Block missing/invalid JWT. Reject actor_id mismatch. Block service-role writes.",
    "internal_writers_require": "Valid short-lived internal JWT with arifOS-internal issuer",
    "external_clients_require": "Valid Supabase OAuth JWT with verified sub claim",
    "actor_id_policy": "jwt sub claim MUST match actor_id in payload"
  },

