{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "apex_verdict",
  "description": "Final Constitutional Verdict - Input Schema",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "Request for judgment"
    },
    "session_id": {
      "type": "string",
      "description": "Optional session identifier"
    },
    "agi_result": {
      "type": "object",
      "description": "Result from AGI reasoning"
    },
    "asi_result": {
      "type": "object",
      "description": "Result from ASI alignment"
    }
  },
  "required": ["query"]
}
