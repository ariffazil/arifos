{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "vault_seal",
  "description": "Cryptographic Seal - Input Schema",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "Seal request"
    },
    "session_id": {
      "type": "string",
      "description": "Optional session identifier"
    },
    "payload": {
      "type": "object",
      "description": "Data to seal"
    },
    "verdict": {
      "type": "string",
      "enum": ["SEAL", "VOID", "SABAR", "PARTIAL", "888_HOLD"]
    }
  },
  "required": ["query"]
}
