  "title": "asi_align",
  "description": "Ethical Alignment Check - Input Schema",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "User input to check"
    },
    "session_id": {
      "type": "string",
      "description": "Optional session identifier"
    },
    "proposed_action": {
      "type": "string",
      "description": "Action to validate"
    }
