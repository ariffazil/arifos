{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Earth Evidence",
  "description": "Canonical schema for geological evidence submitted to arifOS",
  "type": "object",
  "properties": {
    "source": { "type": "string", "description": "Repository or sensor source (e.g., GEOX)" },
    "timestamp": { "type": "string", "format": "date-time" },
    "witness_type": { "enum": ["seismic", "basin", "petrophysical", "structural"] },
    "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "data": { "type": "object" },
    "physics_witness": { "type": "boolean", "const": true }
  },
  "required": ["source", "timestamp", "witness_type", "uncertainty", "physics_witness"]
}
