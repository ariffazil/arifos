{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/agi_sense.schema.json",
  "title": "AGI Sense Output (Stage 111)",
  "description": "Output contract for the AGI sensing stage. Classifies intent, detects ambiguities, and flags risks.",
  "type": "object",
  "required": ["session_id", "intent_lane", "task_type", "entropy_estimate", "risk_flags"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "intent_lane": {
      "type": "string",
      "enum": ["HARD", "SOFT", "PHATIC", "UNKNOWN"],
      "description": "Classification of query intent lane"
    },
    "task_type": {
      "type": "string",
      "description": "Categorized task type (e.g., 'policy_bypass_request', 'capability_inquiry', 'factual_query', 'creative_request')"
    },
    "entropy_estimate": {
      "type": "number",
      "description": "Initial entropy estimate of the query (higher = more ambiguous)"
    },
    "ambiguities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of detected ambiguities in the query"
    },
    "required_clarifications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of clarifications needed before reasoning can proceed"
    },
    "risk_flags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Detected risk indicators (e.g., 'injection_pattern', 'authority_escalation', 'irreversible_action')"
    },
    "hierarchy_level_reached": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Highest hierarchy level reached during sensing (1=PHONETIC, 5=CONCEPTUAL)"
    }
  },
  "additionalProperties": true
}
