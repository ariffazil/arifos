{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arifos://schemas/agi_think.schema.json",
  "title": "AGI Think Output (Stage 222)",
  "description": "Output contract for the AGI thinking stage. Generates hypotheses with explicit assumptions and unknowns.",
  "type": "object",
  "required": ["session_id", "options", "assumptions", "unknowns"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "pros", "cons", "reversible"],
        "properties": {
          "label": {
            "type": "string",
            "description": "Short name for this option"
          },
          "pros": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cons": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reversible": {
            "type": "boolean",
            "description": "Whether this option is reversible (F1 Amanah)"
          },
          "info_needed": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional information needed to evaluate this option"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Confidence in this option (precision-weighted)"
          }
        }
      },
      "description": "Hypothesis options with pros/cons analysis"
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit assumptions underlying the analysis"
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicitly stated unknowns and gaps"
    },
    "precision": {
      "type": "object",
      "properties": {
        "pi_likelihood": { "type": "number" },
        "pi_prior": { "type": "number" },
        "kalman_gain": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      },
      "description": "Precision estimate (Kalman weighting)"
    }
  },
  "additionalProperties": true
}
